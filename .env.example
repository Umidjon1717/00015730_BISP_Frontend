## Local development (backend running locally)
VITE_BASE_URL=http://localhost:3000/api
VITE_BASE_IMAGE_URL=http://localhost:3000
VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

## Production (set these in Vercel > Project > Settings > Environment Variables)
# VITE_BASE_URL=https://<DEPLOYED_BACKEND_DOMAIN>/api
# VITE_BASE_IMAGE_URL=https://<DEPLOYED_BACKEND_DOMAIN>
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

